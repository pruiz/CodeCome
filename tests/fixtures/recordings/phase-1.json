ogic bugs.\n50: \n51:   scope:\n52:     include:\n53:       - \"src/**\"\n54:     exclude:\n55:       - \"src/**/.git/**\"\n56:       - \"src/**/.svn/**\"\n57:       - \"src/**/.hg/**\"\n58:       - \"src/**/node_modules/**\"\n59:       - \"src/**/vendor/**\"\n60:       - \"src/**/packages/**\"\n61:       - \"src/**/bin/**\"\n62:       - \"src/**/obj/**\"\n63:       - \"src/**/target/**\"\n64:       - \"src/**/build/**\"\n65:       - \"src/**/dist/**\"\n66:       - \"src/**/.next/**\"\n67:       - \"src/**/.gradle/**\"\n68:       - \"src/**/.idea/**\"\n69:       - \"src/**/.vscode/**\"\n70: \n71:   focus:\n72:     - \"Authentication and authorization flaws\"\n73:     - \"Injection vulnerabilities\"\n74:     - \"Memory safety issues\"\n75:     - \"Path traversal\"\n76:     - \"Unsafe deserialization\"\n77:     - \"Cryptographic misuse\"\n78:     - \"Secrets exposure\"\n79:     - \"Business logic vulnerabilities\"\n80:     - \"Supply chain risks\"\n81:     - \"Insecure configuration\"\n82:     - \"Improper input validation\"\n83:     - \"Server-side request forgery\"\n84:     - \"File upload vulnerabilities\"\n85:     - \"Race conditions\"\n86:     - \"Privilege escalation\"\n87: \n88: environment:\n89:   type: \"sandbox\"\n90:   path: \"./sandbox\"\n91:   startup_command: \"./sandbox/scripts/up.sh\"\n92:   shell_command: \"./sandbox/scripts/shell.sh\"\n93:   reset_command: \"./sandbox/scripts/reset.sh\"\n94:   logs_command: \"./sandbox/scripts/logs.sh\"\n95:   clean_command: \"./sandbox/scripts/clean.sh\"\n96: \n97: validation:\n98:   worker_count: 1\n99:   allow_destructive_actions_inside_sandbox: true\n100:   allow_source_modification: false\n101: \n102:   allowed_write_paths:\n103:     - \"./itemdb\"\n104:     - \"./runs\"\n105:     - \"./sandbox\"\n106:     - \"./tmp\"\n107:     - \"/workspace/itemdb\"\n108:     - \"/workspace/runs\"\n109:     - \"/workspace/sandbox\"\n110:     - \"/workspace/tmp\"\n111: \n112:   methods:\n113:     - \"static_proof\"\n114:     - \"unit_test\"\n115:     - \"integration_test\"\n116:     - \"runtime_reproduction\"\n117:     - \"sanitizer_detection\"\n118:     - \"crash_reproduction\"\n119:     - \"http_exploit\"\n120:     - \"cli_exploit\"\n121:     - \"file_based_trigger\"\n122:     - \"config_based_trigger\"\n123:     - \"symbolic_or_manual_trace\"\n124:     - \"benchmark_oracle_comparison\"\n125: \n126:   confirmation_policy:\n127:     - \"A finding may only be marked CONFIRMED when clear evidence exists.\"\n128:     - \"Benchmark labels alone are not enough to mark a finding CONFIRMED.\"\n129:     - \"If runtime validation is not practical, a strong static proof may be acceptable, but the limitation must be documented.\"\n130:     - \"If assumptions cannot be validated, keep the finding in PENDING or move it to REJECTED.\"\n131: \n132: reporting:\n133:   format: \"markdown\"\n134:   findings_dir: \"./itemdb/findings\"\n135:   evidence_dir: \"./itemdb/evidence\"\n136:   reports_dir: \"./itemdb/reports\"\n137:   default_status: \"PENDING\"\n138: \n139: finding:\n140:   id_prefix: \"CC\"\n141:   template: \"./templates/finding.md\"\n142: \n143:   statuses:\n144:     - \"PENDING\"\n145:     - \"CONFIRMED\"\n146:     - \"EXPLOITED\"\n147:     - \"REJECTED\"\n148:     - \"DUPLICATE\"\n149: \n150:   severities:\n151:     - \"CRITICAL\"\n152:     - \"HIGH\"\n153:     - \"MEDIUM\"\n154:     - \"LOW\"\n155:     - \"INFO\"\n156: \n157:   confidences:\n158:     - \"LOW\"\n159:     - \"MEDIUM\"\n160:     - \"HIGH\"\n161:     - \"CONFIRMED\"\n162: \n163: skills:\n164:   directory: \"./.opencode/skills\"\n165:   selection_policy:\n166:     - \"Use generic skills by default.\"\n167:     - \"Use target-specific skills only when the target profile, language, or framework matches.\"\n168:     - \"Do not hardcode the workflow around a single target type.\"\n169: \n170: agents:\n171:   directory: \"./.opencode/agents\"\n172:   default_mode: \"single_agent_sequential\"\n173: \n174:   # Optional per-agent model and variant pinning consumed by\n175:   # tools/run-agent.py (the wrapper used by `make phase-*`).\n176:   # Resolution priority: OPENCODE_ARGS > env (CODECOME_MODEL,\n177:   # CODECOME_MODEL_VARIANT) > codecome.yml > unknown.\n178:   #\n179:   # Uncomment and adjust to pin specific models per phase:\n180:   #\n181:   # recon:\n182:   #   model: \"anthropic/claude-opus-4-7\"\n183:   #   variant: \"high\"\n184:   # auditor:\n185:   #   model: \"anthropic/claude-opus-4-7\"\n186:   # reviewer:\n187:   #   model: \"anthropic/claude-opus-4-7\"\n188:   # validator:\n189:   #   model: \"anthropic/claude-opus-4-7\"\n190:   # exploiter:\n191:   #   model: \"anthropic/claude-opus-4-7\"\n192:   # reporter:\n193:   #   model: \"anthropic/claude-opus-4-7\"\n194: \n\n(End of file - total 194 lines)\n</content>","metadata":{"preview":"project:\n  name: \"codecome-target\"\n  source_path: \"./src\"\n  profile: \"auto\"\n  languages:\n    - \"auto\"\n\ntarget:\n  description: \"Source code to be audited by CodeCome.\"\n  assumptions:\n    - \"The agent must infer the target type during reconnaissance.\"\n    - \"The source may be a web app, service, CLI tool, library, benchmark corpus, infrastructure repository, firmware tree, or mixed project.\"\n    - \"Target-specific logic must live in skills, notes, or adapters, not in the core workflow.\"\n\naudit:\n  mode: \"sequential\"\n\n  phases:\n    - reconnaissance\n    - hypothesis_generation","truncated":false,"loaded":[]},"title":"codecome.yml","time":{"start":1779039171643,"end":1779039171654}},"id":"prt_e36ff743a001kmyAIC8133KEdU","sessionID":"ses_1c900d483ffe3X7x4o8qKel0y4","messageID":"msg_e36ff3000001wcz7905lcImUAZ"}}
{"type":"tool_use","timestamp":1779039171656,"sessionID":"ses_1c900d483ffe3X7x4o8qKel0y4","part":{"type":"tool","tool":"read","callID":"call_74aebdd64dec532f","state":{"status":"completed","input":{"filePath":"/Users/pruiz/Develop/mine/CodeCome-e2e-testing/templates/file-risk-index.yml"},"output":"<path>/Users/pruiz/Develop/mine/CodeCome-e2e-testing/templates/file-risk-index.yml</path>\n<type>file</type>\n<content>\n1: # CodeCome file risk index template\n2: #\n3: # Generated during Phase 1 and consumed by optional file-by-file Phase 2 sweeps.\n4: # Scores are intentionally coarse so agents can prioritize attention without\n5: # pretending the ranking is precise.\n6: \n7: schema_version: 1\n8: generated_by: \"phase-1-recon\"\n9: generated_at: \"YYYY-MM-DDTHH:MM:SSZ\"\n10: target: \"codecome-target\"\n11: scoring_scale:\n12:   min: 1\n13:   max: 5\n14:   meaning:\n15:     \"1\": \"Low security interest; unlikely to cross a trust boundary or reach a dangerous sink.\"\n16:     \"2\": \"Some security relevance, but weak attacker control or low impact.\"\n17:     \"3\": \"Moderate interest; plausible source, sink, or security decision.\"\n18:     \"4\": \"High interest; likely attack surface, trust boundary, parser, authz/authn, or dangerous sink.\"\n19:     \"5\": \"Very high interest; externally reachable, security-critical, complex parser, privileged operation, or historically bug-prone surface.\"\n20: \n21: scoring_dimensions:\n22:   - attacker_controlled_input\n23:   - externally_influenced_state\n24:   - trust_boundary_crossing\n25:   - security_decision\n26:   - dangerous_sink\n27:   - parser_complexity\n28:   - privilege_boundary\n29:   - asset_sensitivity\n30:   - historical_vulnerability_density\n31:   - validation_feasibility\n32: \n33: files:\n34:   - path: \"src/example/path/to/file.ext\"\n35:     score: 5\n36:     confidence: \"MEDIUM\"\n37:     target_area: \"example component or feature\"\n38:     reasons:\n39:       - \"Handles attacker-controlled input.\"\n40:       - \"Crosses a trust boundary before reaching a security-sensitive operation.\"\n41:     entry_points:\n42:       - \"HTTP POST /example\"\n43:       - \"CLI argument --example\"\n44:     sources:\n45:       - \"request.body.example\"\n46:     sinks:\n47:       - \"ExampleService.security_sensitive_operation\"\n48:     trust_boundaries:\n49:       - \"untrusted user -> server-side parser\"\n50:     suggested_vulnerability_classes:\n51:       - \"Injection vulnerabilities\"\n52:       - \"Path traversal\"\n53:     suggested_skills:\n54:       - \"web-security\"\n55:     suggested_validation_methods:\n56:       - \"static_proof\"\n57:       - \"http_exploit\"\n58:     notes: \"Replace this example entry with target-specific ranked files.\"\n\n(End of file - total 58 lines)\n</content>","metadata":{"preview":"# CodeCome file risk index template\n#\n# Generated during Phase 1 and consumed by optional file-by-file Phase 2 sweeps.\n# Scores are intentionally coarse so agents can prioritize attention without\n# pretending the ranking is precise.\n\nschema_version: 1\ngenerated_by: \"phase-1-recon\"\ngenerated_at: \"YYYY-MM-DDTHH:MM:SSZ\"\ntarget: \"codecome-target\"\nscoring_scale:\n  min: 1\n  max: 5\n  meaning:\n    \"1\": \"Low security interest; unlikely to cross a trust boundary or reach a dangerous sink.\"\n    \"2\": \"Some security relevance, but weak attacker control or low impact.\"\n    \"3\": \"Moderate interest; plausible source, sink, or security decision.\"\n    \"4\": \"High interest; likely attack surface, trust boundary, parser, authz/authn, or dangerous sink.\"\n    \"5\": \"Very high interest; externally reachable, security-critical, complex parser, privileged operation, or historically bug-prone surface.\"\n","truncated":false,"loaded":[]},"title":"templates/file-risk-index.yml","time":{"start":1779039171646,"end":1779039171655}},"id":"prt_e36ff743d002mRUZkn92jWmw4i","sessionID":"ses_1c900d483ffe3X7x4o8qKel0y4","messageID":"msg_e36ff3000001wcz7905lcImUAZ"}}
{"type":"tool_use","timestamp":1779039171656,"sessionID":"ses_1c900d483ffe3X7x4o8qKel0y4","part":{"type":"tool","tool":"read","callID":"call_a9147156a21b4600","state":{"status":"completed","input":{"filePath":"/Users/pruiz/Develop/mine/CodeCome-e2e-testing/templates/target-recon.md"},"output":"<path>/Users/pruiz/Develop/mine/CodeCome-e2e-testing/templates/target-recon.md</path>\n<type>file</type>\n<content>\n1: # Target Reconnaissance Notes\n2: \n3: Date: YYYY-MM-DD  \n4: Phase: reconnaissance  \n5: Target path: `./src`\n6: \n7: # Executive summary\n8: \n9: Briefly summarize what the target appears to be.\n10: \n11: Include:\n12: \n13: - target type,\n14: - main languages,\n15: - main frameworks or technologies,\n16: - execution model,\n17: - most relevant attack surfaces,\n18: - most relevant validation approach.\n19: \n20: # Target profile\n21: \n22: ## Detected target type\n23: \n24: Examples:\n25: \n26: - web application,\n27: - backend service,\n28: - CLI tool,\n29: - library,\n30: - benchmark corpus,\n31: - infrastructure-as-code repository,\n32: - firmware tree,\n33: - desktop application,\n34: - mobile application,\n35: - mixed repository.\n36: \n37: Detected type:\n38: \n39:     TBD\n40: \n41: Confidence:\n42: \n43:     LOW / MEDIUM / HIGH\n44: \n45: ## Languages\n46: \n47: List detected languages and relevant file patterns.\n48: \n49: ## Frameworks and technologies\n50: \n51: List relevant frameworks, runtimes, package managers, build systems, and deployment technologies.\n52: \n53: ## Repository structure\n54: \n55: Describe the relevant directory layout.\n56: \n57: Focus on directories that matter for security review.\n58: \n59: # Build model\n60: \n61: Describe how the target appears to be built.\n62: \n63: Include:\n64: \n65: - build files,\n66: - package manifests,\n67: - compiler/interpreter requirements,\n68: - test commands,\n69: - generated artifacts,\n70: - build assumptions,\n71: - missing information.\n72: \n73: # Execution model\n74: \n75: Describe how the target appears to run.\n76: \n77: Examples:\n78: \n79: - HTTP service,\n80: - background worker,\n81: - CLI executable,\n82: - library imported by callers,\n83: - benchmark testcase,\n84: - firmware component,\n85: - IaC deployment.\n86: \n87: Include entrypoints and runtime dependencies.\n88: \n89: # Attack surface\n90: \n91: List the detected attack surfaces.\n92: \n93: For each surface, include:\n94: \n95: - name,\n96: - type,\n97: - entrypoints,\n98: - input sources,\n99: - likely attacker control,\n100: - relevant files,\n101: - initial risk notes.\n102: \n103: Example surface types:\n104: \n105: - HTTP route,\n106: - RPC method,\n107: - CLI argument,\n108: - config file,\n109: - environment variable,\n110: - input file parser,\n111: - public library API,\n112: - message queue consumer,\n113: - database migration,\n114: - template renderer,\n115: - authentication flow,\n116: - authorization decision,\n117: - file upload,\n118: - filesystem operation,\n119: - external command execution,\n120: - cryptographic operation,\n121: - deserialization boundary,\n122: - network listener,\n123: - infrastructure exposure.\n124: \n125: # Trust boundaries\n126: \n127: Describe where untrusted or lower-trust data crosses into higher-trust components.\n128: \n129: Examples:\n130: \n131: - anonymous user to authenticated area,\n132: - authenticated user to admin function,\n133: - tenant A to tenant B,\n134: - external webhook to internal processing,\n135: - CLI user input to shell command,\n136: - input file to parser,\n137: - config file to privileged operation,\n138: - network packet to firmware parser,\n139: - user-controlled path to filesystem access.\n140: \n141: # Assets at risk\n142: \n143: List security-relevant assets.\n144: \n145: Examples:\n146: \n147: - user data,\n148: - tenant data,\n149: - credentials,\n150: - private keys,\n151: - tokens,\n152: - certificates,\n153: - filesystem contents,\n154: - database records,\n155: - admin functions,\n156: - signing operations,\n157: - internal network access,\n158: - service availability,\n159: - code execution context.\n160: \n161: # Dangerous sinks\n162: \n163: List security-sensitive sinks found or suspected.\n164: \n165: Examples:\n166: \n167: - raw SQL construction,\n168: - shell command execution,\n169: - filesystem reads/writes,\n170: - path joins,\n171: - template rendering,\n172: - unsafe deserialization,\n173: - memory copy operations,\n174: - pointer arithmetic,\n175: - cryptographic signing,\n176: - token validation,\n177: - authorization checks,\n178: - SSRF-capable HTTP clients,\n179: - XML parsers,\n180: - archive extraction,\n181: - dynamic code loading,\n182: - eval-like behavior,\n183: - privileged API calls.\n184: \n185: # Data flow notes\n186: \n187: Summarize important data flows.\n188: \n189: Focus on flows that may be security-relevant.\n190: \n191: # Security assumptions\n192: \n193: List assumptions made during reconnaissance.\n194: \n195: Mark each as:\n196: \n197: - confirmed,\n198: - likely,\n199: - unknown,\n200: - risky.\n201: \n202: # Interesting files\n203: \n204: List files or directories that should be reviewed during hypothesis generation.\n205: \n206: For each item, explain why it is interesting.\n207: \n208: # Recommended audit focus\n209: \n210: List the vulnerability classes that appear most relevant for this target.\n211: \n212: # Validation model\n213: \n214: Describe how findings should be validated for this target.\n215: \n216: Include:\n217: \n218: - whether the target can be built,\n219: - whether it can be run locally,\n220: - whether Docker is sufficient,\n221: - whether tests exist,\n222: - whether sanitizers/debuggers are useful,\n223: - whether HTTP/CLI/file-based validation applies,\n224: - what evidence should be captured.\n225: \n226: # Limitations\n227: \n228: List what could not be determined during reconnaissance.\n229: \n230: # Next steps\n231: \n232: Concrete recommendations for phase 2.\n\n(End of file - total 232 lines)\n</content>","metadata":{"preview":"# Target Reconnaissance Notes\n\nDate: YYYY-MM-DD  \nPhase: reconnaissance  \nTarget path: `./src`\n\n# Executive summary\n\nBriefly summarize what the target appears to be.\n\nInclude:\n\n- target type,\n- main languages,\n- main frameworks or technologies,\n- execution model,\n- most relevant attack surfaces,\n- most relevant validation approach.\n\n# Target profile","truncated":false,"loaded":[]},"title":"templates/target-recon.md","time":{"start":1779039171645,"end":1779039171655}},"id":"prt_e36ff743c001o1gt8jafoxbVbL","sessionID":"ses_1c900d483ffe3X7x4o8qKel0y4","messageID":"msg_e36ff3000001wcz7905lcImUAZ"}}
