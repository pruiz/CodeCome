{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./.opencode/plugins/status-forwarder.ts"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "src/**/.env": "allow",
      "src/**/.env.*": "allow",
      "*/src/**/.env": "allow",
      "*/src/**/.env.*": "allow",
      "sandbox/.env": "allow",
      "*/sandbox/.env": "allow"
    }
  }
}
