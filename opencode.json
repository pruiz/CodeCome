{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./.opencode/plugins/status-forwarder.ts"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "src/**/.env": "allow",
      "src/**/.env.*": "allow",
      "*/src/**/.env": "allow",
      "*/src/**/.env.*": "allow",
      "sandbox/.env": "allow",
      "*/sandbox/.env": "allow"
    }
  },
  "provider": {
    "test": {
      "type": "openai",
      "options": {
        "baseURL": "http://127.0.0.1:50400/v1",
        "apiKey": "sk-test"
      },
      "models": {
        "mockmodel": {}
      }
    }
  },
  "agent": {
    "test": {
      "temperature": 0,
      "top_p": 1
    }
  }
}
