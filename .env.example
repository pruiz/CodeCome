# CodeCome environment variables
#
# Copy this file to `.env` if you need local overrides.
#
# The initial PoC does not require any secrets.
# Do not commit real credentials, tokens, private keys, or production URLs.

CODECOME_PROJECT_NAME=codecome-target
CODECOME_SOURCE_PATH=./src
CODECOME_SANDBOX_PATH=./sandbox
CODECOME_ITEMDB_PATH=./itemdb

# Optional target fetch settings.
# Leave empty unless a target-specific setup script uses them.

TARGET_REPOSITORY_URL=
TARGET_REPOSITORY_REF=
TARGET_ARCHIVE_URL=

# Optional sandbox settings.

COMPOSE_PROJECT_NAME=codecome
